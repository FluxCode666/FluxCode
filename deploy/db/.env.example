# =============================================================================
# Sub2API Database Environment (Multi-Machine)
# =============================================================================
# Deploy on: Database machine
# Usage: cp .env.db.example .env && nano .env
#
# Security: Use firewall rules to only allow backend machine IPs
#           to connect to ports 5432 and 6379.
# =============================================================================

BIND_HOST=0.0.0.0
TZ=Asia/Shanghai

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_PORT=5432
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=sub2api

# PostgreSQL server parameters
POSTGRES_MAX_CONNECTIONS=256
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1GB
POSTGRES_MAINTENANCE_WORK_MEM=64MB

# =============================================================================
# Redis
# =============================================================================
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_MAXCLIENTS=10000
