# =============================================================================
# Sub2API Docker Environment Configuration (Cluster Mode)
# =============================================================================
# Copy this file to .env and modify as needed:
#   cp .env.cluster.example .env
#   nano .env
#
# Then start with: docker compose -f docker-compose.cluster.yml up -d
#
# For multi-machine deployment, see README_CLUSTER.md
# =============================================================================

# =============================================================================
# CLUSTER-SPECIFIC CONFIGURATION
# =============================================================================

# Frontend (Nginx) exposed port
FRONTEND_PORT=80

# Bind address for host port mapping
BIND_HOST=0.0.0.0

# =============================================================================
# REQUIRED: Database Configuration
# =============================================================================
# For single-machine cluster: use "postgres" (Docker service name)
# For multi-machine: use actual database host IP/hostname
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=sub2api
DATABASE_PASSWORD=change_this_secure_password
DATABASE_DBNAME=sub2api
DATABASE_SSLMODE=disable

# Connection pool (per backend instance)
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# =============================================================================
# REQUIRED: Redis Configuration
# =============================================================================
# For single-machine cluster: use "redis" (Docker service name)
# For multi-machine: use actual Redis host IP/hostname
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT_SECONDS=5
REDIS_READ_TIMEOUT_SECONDS=3
REDIS_WRITE_TIMEOUT_SECONDS=3
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# =============================================================================
# REQUIRED: Security Keys (MUST be identical across all backend instances!)
# =============================================================================
# Generate: openssl rand -hex 32
# WARNING: All backend instances MUST share the same JWT_SECRET, otherwise
# users will be logged out when their request hits a different backend.
JWT_SECRET=
JWT_EXPIRE_HOUR=24

# Generate: openssl rand -hex 32
# WARNING: All backend instances MUST share the same TOTP_ENCRYPTION_KEY,
# otherwise 2FA will break across instances.
TOTP_ENCRYPTION_KEY=

# =============================================================================
# Server Configuration
# =============================================================================
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# =============================================================================
# Admin Account (auto-created on first run of first backend instance)
# =============================================================================
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=json
LOG_SERVICE_NAME=sub2api
LOG_ENV=production
LOG_CALLER=true
LOG_STACKTRACE_LEVEL=error
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=true
LOG_OUTPUT_FILE_PATH=
LOG_ROTATION_MAX_SIZE_MB=100
LOG_ROTATION_MAX_BACKUPS=10
LOG_ROTATION_MAX_AGE_DAYS=7
LOG_ROTATION_COMPRESS=true
LOG_ROTATION_LOCAL_TIME=true
LOG_SAMPLING_ENABLED=false
LOG_SAMPLING_INITIAL=100
LOG_SAMPLING_THEREAFTER=100

# =============================================================================
# Gateway Configuration
# =============================================================================
SERVER_MAX_REQUEST_BODY_SIZE=268435456
GATEWAY_MAX_BODY_SIZE=268435456
SERVER_H2C_ENABLED=true
SERVER_H2C_MAX_CONCURRENT_STREAMS=50
GATEWAY_MAX_CONNS_PER_HOST=2048
GATEWAY_MAX_IDLE_CONNS=8192
GATEWAY_MAX_IDLE_CONNS_PER_HOST=4096
GATEWAY_FORCE_CODEX_CLI=false
GATEWAY_SCHEDULING_STICKY_SESSION_MAX_WAITING=3
GATEWAY_SCHEDULING_STICKY_SESSION_WAIT_TIMEOUT=120s
GATEWAY_SCHEDULING_FALLBACK_WAIT_TIMEOUT=30s
GATEWAY_SCHEDULING_FALLBACK_MAX_WAITING=100
GATEWAY_SCHEDULING_LOAD_BATCH_ENABLED=true
GATEWAY_SCHEDULING_SLOT_CLEANUP_INTERVAL=30s
GATEWAY_SCHEDULING_DB_FALLBACK_ENABLED=true

# =============================================================================
# Dashboard Aggregation
# =============================================================================
DASHBOARD_AGGREGATION_ENABLED=true
DASHBOARD_AGGREGATION_INTERVAL_SECONDS=60

# =============================================================================
# Security Configuration
# =============================================================================
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=true
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=true

# =============================================================================
# Gemini OAuth (Optional)
# =============================================================================
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
GEMINI_QUOTA_POLICY=
GEMINI_CLI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=

# =============================================================================
# Ops Monitoring
# =============================================================================
OPS_ENABLED=true

# =============================================================================
# Update Proxy (Optional)
# =============================================================================
UPDATE_PROXY_URL=

# =============================================================================
# PostgreSQL Server Parameters (only if using built-in postgres service)
# =============================================================================
POSTGRES_MAX_CONNECTIONS=1024
POSTGRES_SHARED_BUFFERS=1GB
POSTGRES_EFFECTIVE_CACHE_SIZE=4GB
POSTGRES_MAINTENANCE_WORK_MEM=128MB

# Redis Server Parameters (only if using built-in redis service)
REDIS_MAXCLIENTS=50000
