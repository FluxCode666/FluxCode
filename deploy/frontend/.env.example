# =============================================================================
# Sub2API Frontend Environment (Multi-Machine)
# =============================================================================
# Deploy on: Frontend / Load Balancer machine
# Usage: cp .env.example .env && nano .env
#
# Supports two web servers:
#   Nginx: docker compose up -d                          (docker-compose.yml)
#   Caddy: docker compose -f docker-compose.caddy.yml up -d
# =============================================================================

# Bind address
BIND_HOST=0.0.0.0

# Frontend HTTP port
FRONTEND_PORT=80

# Frontend HTTPS port (Caddy only, auto-enabled when SITE_DOMAIN is a real domain)
FRONTEND_HTTPS_PORT=443

# =============================================================================
# REQUIRED: Backend server addresses
# =============================================================================
# Comma-separated list of backend IP:PORT pairs.
# The entrypoint script will generate upstream configuration from this.
#
# Examples:
#   Single backend:   BACKEND_SERVERS=10.0.1.10:8080
#   Multiple backends: BACKEND_SERVERS=10.0.1.10:8080,10.0.1.11:8080,10.0.1.12:8080
BACKEND_SERVERS=10.0.1.10:8080

# =============================================================================
# Caddy specific settings (docker-compose.caddy.yml only)
# =============================================================================
# Domain name for HTTPS.
# Set to a real domain (e.g. "api.sub2api.com") to enable HTTPS.
# Set to ":80" for HTTP-only mode (default, no TLS).
SITE_DOMAIN=:80

# --- TLS mode ---
# Caddy supports 3 种 TLS 模式:
#
# 1) 自动 HTTPS (默认):
#    设置 SITE_DOMAIN 为真实域名，不设置 TLS_CERT/TLS_KEY。
#    Caddy 自动通过 Let's Encrypt / ZeroSSL 申请和续期证书。
#    注意：域名必须解析到本机公网 IP，且 80/443 端口可达。
#
# 2) 手动证书 (适合多 Caddy 实例共享同一域名):
#    设置 SITE_DOMAIN 为域名，同时设置 TLS_CERT 和 TLS_KEY 指向证书文件。
#    所有 Caddy 实例挂载相同的证书文件即可，不会触发 ACME 申请。
#    证书续期需自行管理（certbot / acme.sh 等），续期后重启容器生效。
#    docker-compose.caddy.yml 中取消 ssl volume 挂载的注释。
#
# 3) HTTP only:
#    设置 SITE_DOMAIN=:80，不设置 TLS_CERT/TLS_KEY。
#    适合前面有外部 LB (Cloudflare / 云 SLB) 做 TLS 终止的场景。

# Manual TLS certificate path (inside container)
# Uncomment and set when using manual cert mode:
# TLS_CERT=/etc/caddy/ssl/fullchain.pem
# TLS_KEY=/etc/caddy/ssl/privkey.pem
TLS_CERT=
TLS_KEY=
