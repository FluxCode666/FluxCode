# =============================================================================
# Sub2API Backend Environment (Multi-Machine)
# =============================================================================
# Deploy on: Each backend machine
# Usage: cp .env.example .env && nano .env && docker compose up -d
#
# IMPORTANT: JWT_SECRET and TOTP_ENCRYPTION_KEY must be IDENTICAL
#            across ALL backend instances!
# =============================================================================

# =============================================================================
# Docker Image Configuration
# =============================================================================
# Override to use DockerHub or custom registry:
#   BACKEND_IMAGE=fluxcode666/fluxcode-backend
#   BACKEND_IMAGE=your-registry.com/fluxcode-backend
BACKEND_IMAGE=ghcr.io/fluxcode666/fluxcode-backend
BACKEND_TAG=latest

BIND_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# =============================================================================
# REQUIRED: External Database
# =============================================================================
DATABASE_HOST=10.0.1.100
DATABASE_PORT=5432
DATABASE_USER=sub2api
DATABASE_PASSWORD=change_this_secure_password
DATABASE_DBNAME=sub2api
DATABASE_SSLMODE=disable
DATABASE_MAX_OPEN_CONNS=50
DATABASE_MAX_IDLE_CONNS=10
DATABASE_CONN_MAX_LIFETIME_MINUTES=30
DATABASE_CONN_MAX_IDLE_TIME_MINUTES=5

# =============================================================================
# REQUIRED: External Redis
# =============================================================================
REDIS_HOST=10.0.1.100
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_DIAL_TIMEOUT_SECONDS=5
REDIS_READ_TIMEOUT_SECONDS=3
REDIS_WRITE_TIMEOUT_SECONDS=3
REDIS_POOL_SIZE=1024
REDIS_MIN_IDLE_CONNS=10
REDIS_ENABLE_TLS=false

# =============================================================================
# REQUIRED: Security Keys (MUST be identical across all instances!)
# =============================================================================
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRE_HOUR=24

# Generate: openssl rand -hex 32
TOTP_ENCRYPTION_KEY=

# =============================================================================
# Admin Account (auto-created on first instance startup)
# =============================================================================
ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=

# =============================================================================
# Gemini OAuth (optional)
# =============================================================================
GEMINI_OAUTH_CLIENT_ID=
GEMINI_OAUTH_CLIENT_SECRET=
GEMINI_OAUTH_SCOPES=
GEMINI_QUOTA_POLICY=
GEMINI_CLI_OAUTH_CLIENT_SECRET=
ANTIGRAVITY_OAUTH_CLIENT_SECRET=

# =============================================================================
# Security
# =============================================================================
SECURITY_URL_ALLOWLIST_ENABLED=false
SECURITY_URL_ALLOWLIST_ALLOW_INSECURE_HTTP=true
SECURITY_URL_ALLOWLIST_ALLOW_PRIVATE_HOSTS=true

# =============================================================================
# Update Proxy (optional)
# =============================================================================
UPDATE_PROXY_URL=
